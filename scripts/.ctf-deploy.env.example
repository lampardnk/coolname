# CTF Deployment Config
# Copy this to scripts/.ctf-deploy.env and fill in the values.
# scripts/.ctf-deploy.env is gitignored — never commit it.

# ── CTFd ─────────────────────────────────────────────────────────────────────
# URL: use the current head node external IP (changes each VM start)
CTFD_URL=http://<HEAD_IP>

# Admin API token: CTFd admin > top-right user menu > Profile > API Tokens > Generate
CTFD_TOKEN=<admin-api-token>

# ── Artifact Registry ─────────────────────────────────────────────────────────
# Base path for challenge Docker images (no trailing slash)
AR_IMAGES=asia-southeast1-docker.pkg.dev/<PROJECT_ID>/ctf-images

# Base path for Pulumi scenario OCI artifacts (no trailing slash)
AR_SCENARIOS=asia-southeast1-docker.pkg.dev/<PROJECT_ID>/ctf-scenarios

# ── GKE ingress ───────────────────────────────────────────────────────────────
# Traefik load balancer IP — STATIC, never changes
TRAEFIK_IP=<TRAEFIK_LB_IP>
# This is used to build per-player URLs: <uuid>-<slug>.<TRAEFIK_IP>.nip.io
